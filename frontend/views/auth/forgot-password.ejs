<%- include('../partials/head') %>
</head>
<body class="bg-light">
  <%- include('../partials/navbar', { session: session }) %>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
          <div class="card-body p-4">
            <h2 class="text-center mb-4">Forgot Password</h2>
            
            <% if (error_msg) { %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>
            
            <% if (success_msg) { %>
              <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <form action="/forgot-password" method="POST">
              <div class="mb-3">
                <label for="emailOrPhone" class="form-label">Email or Phone Number</label>
                <input 
                  type="text" 
                  class="form-control" 
                  id="emailOrPhone" 
                  name="emailOrPhone" 
                  required
                  autofocus
                >
                <div class="form-text">Enter your email address or phone number to receive a password reset link.</div>
              </div>
              
              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Send Reset Link</button>
                <div class="text-center mt-3">
                  <a href="/login" class="text-decoration-none">Back to Login</a>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>
