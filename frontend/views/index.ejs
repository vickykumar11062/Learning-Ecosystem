<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduLearn - Master New Skills</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');

        :root {
            --primary: #667eea;
            --secondary: #764ba2;
            --accent: #f093fb;
            --dark: #0f172a;
            --light: #f8fafc;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
        }

        /* Hero Section */
        .hero-section {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            padding-top: 70px;
            margin-top: -70px;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
            animation: moveBackground 15s ease-in-out infinite;
            z-index: 1;
        }

        @keyframes moveBackground {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-50px, -50px); }
        }

        .particle {
            position: absolute;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            z-index: 2;
            pointer-events: none;
        }

        .particle-1 { width: 80px; height: 80px; top: 15%; left: 10%; animation: float 8s ease-in-out infinite; }
        .particle-2 { width: 60px; height: 60px; top: 70%; left: 80%; animation: float 6s ease-in-out infinite 1s; }
        .particle-3 { width: 100px; height: 100px; top: 40%; right: 15%; animation: float 10s ease-in-out infinite 2s; }

        @keyframes float {
            0%, 100% { transform: translateY(0); opacity: 0.3; }
            50% { transform: translateY(-40px); opacity: 0.6; }
        }

        .hero-content {
            position: relative;
            z-index: 10;
            padding: 4rem 0;
        }

        .badge-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            padding: 0.7rem 1.5rem;
            border-radius: 50px;
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
            animation: slideDown 0.8s ease-out;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero-title {
            font-size: 4rem;
            font-weight: 800;
            color: white;
            line-height: 1.1;
            margin: 2rem 0 1.5rem;
            animation: fadeInUp 1s ease-out 0.2s both;
            text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        .gradient-text {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-subtitle {
            font-size: 1.3rem;
            color: rgba(255, 255, 255, 0.95);
            line-height: 1.8;
            margin-bottom: 2.5rem;
            animation: fadeInUp 1s ease-out 0.4s both;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .btn-hero {
            padding: 1.1rem 2.5rem;
            font-weight: 600;
            font-size: 1.1rem;
            border-radius: 50px;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-primary-custom {
            background: white;
            color: #667eea;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }

        .btn-primary-custom:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
        
        .btn-hero[href="/about"] {
            background: transparent;
            color: white;
            border: 2px solid white;
        }
        
        .btn-hero[href="/about"]:hover {
            background: white !important;
            color: #667eea !important;
        }

        .stats-wrapper {
            margin-top: 4rem;
            display: flex;
            gap: 4rem;
            animation: fadeInUp 1s ease-out 0.8s both;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 800;
            color: white;
            text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        .stat-label {
            color: rgba(255, 255, 255, 0.9);
            font-size: 1rem;
        }

        /* Features Section */
        .features-section {
            padding: 6rem 0;
            background: #f8fafc;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #0f172a;
            text-align: center;
            margin-bottom: 1rem;
        }

        .section-subtitle {
            text-align: center;
            color: #64748b;
            font-size: 1.1rem;
            margin-bottom: 4rem;
        }

        .feature-card {
            background: white;
            border-radius: 20px;
            padding: 2.5rem;
            transition: all 0.3s ease;
            border: 1px solid #e2e8f0;
            height: 100%;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        }

        .feature-icon {
            width: 70px;
            height: 70px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1.5rem;
        }

        .icon-purple { background: linear-gradient(135deg, #667eea, #764ba2); color: white; }
        .icon-pink { background: linear-gradient(135deg, #ec4899, #f43f5e); color: white; }
        .icon-blue { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
        .icon-green { background: linear-gradient(135deg, #10b981, #059669); color: white; }

        .feature-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 1rem;
        }

        .feature-text {
            color: #64748b;
            line-height: 1.6;
        }

        /* Popular Courses Section */
        .courses-section {
            padding: 6rem 0;
            background: white;
        }

        .course-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            height: 100%;
        }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }

        .course-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .course-body {
            padding: 1.5rem;
        }

        .course-category {
            background: #ede9fe;
            color: #7c3aed;
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 1rem;
        }

        .course-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 1rem;
        }

        .course-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .rating {
            color: #fbbf24;
        }

        .course-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid #e2e8f0;
        }

        .course-price {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* CTA Section */
        .cta-section {
            padding: 6rem 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-align: center;
        }

        .cta-title {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
        }

        .cta-text {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            opacity: 0.95;
        }

        /* ========== MOBILE RESPONSIVE STYLES ========== */
        
        /* Tablets and smaller (below 992px) */
        @media (max-width: 991px) {
            .hero-title {
                font-size: 3rem;
            }

            .hero-subtitle {
                font-size: 1.1rem;
            }

            .stats-wrapper {
                gap: 2rem;
            }

            .stat-number {
                font-size: 2.5rem;
            }

            .section-title {
                font-size: 2rem;
            }

            .cta-title {
                font-size: 2.5rem;
            }
        }

        /* Mobile devices (below 768px) */
        @media (max-width: 767px) {
            .hero-section {
                min-height: auto;
                padding: 2rem 1.5rem 3rem;
            }
            
            .hero-content {
                padding-left: 1rem;
                padding-right: 1rem;
            }

            .hero-content {
                padding: 2rem 0;
            }

            .badge-pill {
                padding: 0.6rem 1.2rem;
                font-size: 0.8rem;
            }

            .hero-title {
                font-size: 2.2rem;
                margin: 1.5rem 0 1rem;
                line-height: 1.2;
            }

            .hero-subtitle {
                font-size: 1rem;
                margin-bottom: 1.5rem;
                line-height: 1.6;
            }

            .btn-hero {
                padding: 0.9rem 2rem;
                font-size: 1rem;
                width: 100%;
            }

            .stats-wrapper {
                margin-top: 2.5rem;
                gap: 1.5rem;
                flex-wrap: wrap;
                justify-content: center;
            }

            .stat-card {
                text-align: center;
                min-width: 100px;
            }

            .stat-number {
                font-size: 2rem;
            }

            .stat-label {
                font-size: 0.85rem;
            }

            /* Hero Image */
            .hero-section .col-lg-6:last-child {
                margin-top: 2rem !important;
            }

            .hero-section img {
                max-height: 50vh !important;
            }

            /* Particles - smaller on mobile */
            .particle-1 { width: 50px; height: 50px; }
            .particle-2 { width: 40px; height: 40px; }
            .particle-3 { width: 60px; height: 60px; }

            /* Sections */
            .features-section,
            .courses-section,
            .cta-section {
                padding: 3rem 0;
            }

            .section-title {
                font-size: 1.75rem;
                margin-bottom: 0.75rem;
            }

            .section-subtitle {
                font-size: 0.95rem;
                margin-bottom: 2rem;
                padding: 0 1rem;
            }

            /* Feature Cards */
            .feature-card {
                padding: 2rem 1.5rem;
                margin-bottom: 1rem;
            }

            .feature-icon {
                width: 60px;
                height: 60px;
                font-size: 1.5rem;
                margin-bottom: 1rem;
            }

            .feature-title {
                font-size: 1.2rem;
            }

            .feature-text {
                font-size: 0.9rem;
            }

            /* Course Cards */
            .course-card {
                margin-bottom: 1.5rem;
            }

            .course-image {
                height: 180px;
            }

            .course-body {
                padding: 1.25rem;
            }

            .course-title {
                font-size: 1.1rem;
            }

            .course-meta {
                font-size: 0.85rem;
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            .course-price {
                font-size: 1.5rem;
            }

            /* CTA Section */
            .cta-title {
                font-size: 1.75rem;
                margin-bottom: 1rem;
            }

            .cta-text {
                font-size: 1rem;
                margin-bottom: 1.5rem;
                padding: 0 1rem;
            }
        }

        /* Small mobile devices (below 576px) */
        @media (max-width: 575px) {
            .hero-title {
                font-size: 1.85rem;
            }

            .hero-subtitle {
                font-size: 0.9rem;
            }

            .btn-hero {
                padding: 0.85rem 1.5rem;
                font-size: 0.95rem;
            }

            .stats-wrapper {
                gap: 1rem;
            }

            .stat-number {
                font-size: 1.75rem;
            }

            .stat-label {
                font-size: 0.75rem;
            }

            .section-title {
                font-size: 1.5rem;
            }

            .section-subtitle {
                font-size: 0.9rem;
            }

            .feature-card {
                padding: 1.5rem;
            }

            .feature-icon {
                width: 50px;
                height: 50px;
                font-size: 1.25rem;
            }

            .feature-title {
                font-size: 1.1rem;
            }

            .cta-title {
                font-size: 1.5rem;
            }

            .cta-text {
                font-size: 0.9rem;
            }
        }

        /* Landscape mobile orientation */
        @media (max-width: 767px) and (orientation: landscape) {
            .hero-section {
                min-height: auto;
            }

            .hero-title {
                font-size: 2rem;
                margin: 1rem 0 0.75rem;
            }

            .hero-subtitle {
                font-size: 0.95rem;
                margin-bottom: 1rem;
            }

            .stats-wrapper {
                margin-top: 1.5rem;
                gap: 2rem;
            }

            .stat-number {
                font-size: 1.5rem;
            }

            .hero-section img {
                max-height: 40vh !important;
            }
        }

        /* 🌙 Improved Dark Mode Styling */
        body.dark-theme {
          background: #0e0e0e !important;
          color: #e6e6e6 !important;
          transition: background 0.3s ease, color 0.3s ease;
        }

        /* Hero Section */
        body.dark-theme .hero-section {
          background: linear-gradient(135deg, #141414, #0f0f0f, #1a1a1a) !important;
        }
        body.dark-theme .hero-title {
          color: #ffffff !important;
          text-shadow: 0 0 25px rgba(120, 93, 255, 0.4);
        }
        body.dark-theme .hero-subtitle {
          color: #d8d8d8 !important;
        }
        body.dark-theme .badge-pill {
          background: rgba(255, 255, 255, 0.1) !important;
          border-color: rgba(255, 255, 255, 0.2);
        }

        /* Feature section */
        body.dark-theme .features-section {
          background: #111 !important;
        }
        body.dark-theme .feature-card {
          background: #181818 !important;
          border-color: #333 !important;
          box-shadow: 0 5px 25px rgba(0,0,0,0.5) !important;
        }
        body.dark-theme .feature-title {
          color: #fff !important;
        }
        body.dark-theme .feature-text {
          color: #c9c9c9 !important;
        }

        /* Course Section */
        body.dark-theme .courses-section {
          background: #111 !important;
        }
        body.dark-theme .course-card {
          background: #1c1c1c !important;
          border-color: #333 !important;
          box-shadow: 0 5px 25px rgba(0,0,0,0.5) !important;
        }
        body.dark-theme .course-title {
          color: #fff !important;
        }
        body.dark-theme .course-meta {
          color: #b3b3b3 !important;
        }
        body.dark-theme .course-category {
          background: #272727 !important;
          color: #9b87ff !important;
        }

        /* CTA */
        body.dark-theme .cta-section {
          background: linear-gradient(135deg, #151515 0%, #000 100%) !important;
          color: #fff !important;
        }
        body.dark-theme .cta-title {
          text-shadow: 0 0 25px rgba(120, 93, 255, 0.4);
        }

        /* Contact Section */
        body.dark-theme section.py-5.bg-light {
          background: #111 !important;
          color: white !important;
        }
        body.dark-theme .btn-primary {
          background: #7c5bff !important;
          border: none;
        }
        body.dark-theme .btn-primary:hover {
          background: #9d89ff !important;
        }

        /* Button improvements */
        body.dark-theme .btn-hero {
          box-shadow: 0 0 25px rgba(124, 91, 255, 0.3) !important;
        }

        /* Cards hover glow */
        body.dark-theme .feature-card:hover,
        body.dark-theme .course-card:hover {
          transform: translateY(-6px);
          box-shadow: 0 0 30px rgba(124, 91, 255, 0.3) !important;
        }

        /* Social icons & icons */
        body.dark-theme i {
          color: #cfcfcf;
        }

        /* Modal */
        body.dark-theme .modal-content {
          background: #1a1a1a;
          color: #fff;
        }

        /* ================= HERO SECTION UPGRADE (Dark Mode) ================= */
        body.dark-theme .hero-section {
          background: radial-gradient(circle at top left, #141414 0%, #0d0d0d 40%, #000000 90%) !important;
          position: relative;
        }

        body.dark-theme .hero-title {
          font-size: 4rem;
          font-weight: 900;
          background: linear-gradient(135deg, #9d7dff 0%, #ff71c8 50%, #ffd86b 100%);
          -webkit-background-clip: text;
          background-clip: text;
          -webkit-text-fill-color: transparent;
          letter-spacing: 1px;
          text-shadow: 0 0 30px rgba(146, 110, 255, 0.4);
        }

        body.dark-theme .hero-subtitle {
          font-size: 1.25rem;
          color: #dcdcdc !important;
          line-height: 1.8;
          text-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        /* Glow effect particles animation */
        body.dark-theme .particle {
          background: rgba(146, 110, 255, 0.25) !important;
          filter: blur(2px);
        }

        /* CTA Buttons */
        body.dark-theme .btn-primary-custom {
          background: linear-gradient(135deg, #9d7dff, #ff71c8);
          color: white !important;
          box-shadow: 0 0 20px rgba(255, 113, 200, 0.4);
        }
        body.dark-theme .btn-primary-custom:hover {
          transform: translateY(-5px);
          box-shadow: 0 0 40px rgba(255, 113, 200, 0.65);
        }

        /* About button specific styling in dark mode */
        body.dark-theme .btn-hero[href="/about"] {
          background: transparent !important;
          color: white !important;
          border: 2px solid white !important;
          box-shadow: none !important;
        }
        
        body.dark-theme .btn-hero[href="/about"]:hover {
          background: white !important;
          color: #667eea !important;
          box-shadow: 0 0 20px rgba(255, 255, 255, 0.3) !important;
        }

        /* ============ SECTION HEADING UPGRADE ============ */
        .section-title {
          font-weight: 800 !important;
          position: relative;
          display: inline-block;
          padding-bottom: 10px;
          text-align: center;
          width: 100%;
        }

        body.dark-theme .section-title {
          font-size: 2.6rem;
          background: linear-gradient(135deg, #9d7dff, #ff71c8, #ffd86b);
          -webkit-background-clip: text;
          background-clip: text;
          -webkit-text-fill-color: transparent;
          text-shadow: 0 0 35px rgba(146, 110, 255, 0.25);
        }

        .section-title::after {
          content: '';
          position: absolute;
          width: 80px;
          height: 4px;
          background: linear-gradient(135deg, #667eea, #764ba2);
          left: 50%;
          bottom: 0;
          transform: translateX(-50%);
          border-radius: 10px;
        }

        body.dark-theme .section-title::after {
          background: linear-gradient(135deg, #9d7dff, #ff71c8);
          box-shadow: 0 0 18px rgba(255, 113, 200, 0.7);
        }

        /* Section subtitle */
        body.dark-theme .section-subtitle {
          color: #bfbfbf !important;
          font-size: 1.15rem;
          text-shadow: 0 0 20px rgba(0,0,0,0.4);
        }

        /* Fix unwanted text cursor in index hero area */
        .hero-section *,
        .features-section *,
        .courses-section *,
        .cta-section *,
        section *,
        div,
        p,
        h1,
        h2,
        h3,
        h4,
        h5,
        h6,
        span {
          user-select: none !important;
          cursor: default !important;
        }

        /* Allow typing only in inputs */
        input, textarea {
          user-select: text !important;
          cursor: text !important;
        }

        /* Pointer where needed */
        button, a, .btn {
          cursor: pointer !important;
        }
    </style>
</head>
<body class="">
    <%- include('./partials/navbar') %>
    
    <!-- Spacer for fixed navbar -->
    <div style="height: 30px;"></div>

    <!-- Hero Section -->
    <section class="hero-section position-relative">
        <!-- Flash Messages -->
        <div class="flash-messages" style="position: fixed; top: 80px; left: 50%; transform: translateX(-50%); z-index: 9999; width: auto; max-width: 500px; min-width: 300px; padding: 0 15px;">
            <% if (success_msg) { %>
                <% (Array.isArray(success_msg) ? success_msg : [success_msg]).forEach(function(msg) { %>
                    <% if (msg && typeof msg === 'string' && msg.trim() !== '') { %>
                        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert" style="border-radius: 0 !important;">
                            <div class="container d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-check-circle me-2"></i>
                                    <%= msg %>
                                </div>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        </div>
                    <% } %>
                <% }); %>
            <% } %>
            
            <% if (error_msg) { %>
                <% (Array.isArray(error_msg) ? error_msg : [error_msg]).forEach(function(msg) { %>
                    <% if (msg && typeof msg === 'string' && msg.trim() !== '') { %>
                        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert" style="border-radius: 0 !important;">
                            <div class="container d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-exclamation-circle me-2"></i>
                                    <%= msg %>
                                </div>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        </div>
                    <% } %>
                <% }); %>
            <% } %>
        </div>
        
        <div class="particle particle-1"></div>
        <div class="particle particle-2"></div>
        <div class="particle particle-3"></div>

        <div class="container hero-content">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="badge-pill">
                        <i class="fa-solid fa-trophy"></i>
                        #1 Rated Learning Platform
                    </div>
                    
                    <h1 class="hero-title">
                        Transform Your Career With <span class="gradient-text">Expert Courses</span>
                    </h1>
                    
