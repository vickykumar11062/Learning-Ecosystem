    <!-- Button Loader Script -->
    <script>
    // Button Loader Utility
    document.addEventListener('DOMContentLoaded', function() {
        // Handle buttons with data-loading-text
        document.querySelectorAll('a[data-loading-text], button[data-loading-text]').forEach(button => {
            button.addEventListener('click', function(e) {
                // Don't prevent default for links that should navigate
                const isLink = this.tagName === 'A';
                const loadingText = this.getAttribute('data-loading-text');
                
                if (loadingText) {
                    // Save original content if not already saved
                    if (!this.hasAttribute('data-original-html')) {
                        this.setAttribute('data-original-html', this.innerHTML);
                    }
                    
                    // Show loading state
                    this.innerHTML = `
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        ${loadingText}
                    `;
                    
                    // For forms, don't disable the button to allow form submission
                    if (!isLink && !this.closest('form')) {
                        this.disabled = true;
                    }
                    
                    // For links, wait a bit before navigation to show loading state
                    if (isLink) {
                        e.preventDefault();
                        const href = this.getAttribute('href');
                        setTimeout(() => {
                            window.location.href = href;
                        }, 100);
                    }
                }
            });
        });
    });
    </script>
    
    <script>
    // Show contact modal if URL has #contact hash or if there's a flash message about registration
    document.addEventListener('DOMContentLoaded', function() {
        // Check for hash in URL
        if (window.location.hash === '#contact') {
            const contactModal = new bootstrap.Modal(document.getElementById('contactModal'));
            contactModal.show();
        }
        
        // Check for flash messages
        const flashMessage = document.querySelector('.alert.alert-info');
        if (flashMessage && flashMessage.textContent.includes('contact the developer')) {
            const contactModal = new bootstrap.Modal(document.getElementById('contactModal'));
            contactModal.show();
        }
    });
    </script>
