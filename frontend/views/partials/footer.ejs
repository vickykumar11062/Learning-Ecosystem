    <script>
    // Show contact modal if URL has #contact hash or if there's a flash message about registration
    document.addEventListener('DOMContentLoaded', function() {
        if (window.location.hash === '#contact' || 
            (document.querySelector('.alert.alert-info') && 
             document.querySelector('.alert.alert-info').textContent.includes('contact the developer'))) {
            const contactModal = new bootstrap.Modal(document.getElementById('contactModal'));
            contactModal.show();
        }
    });
    </script>
    
    <script>
