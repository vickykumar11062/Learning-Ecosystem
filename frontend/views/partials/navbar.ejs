<!-- Navbar JavaScript -->
<script>
  // Add active class to current nav link
  document.addEventListener('DOMContentLoaded', function() {
    // Get current URL path
    const currentPath = window.location.pathname;
    
    // Find all nav links
    const navLinks = document.querySelectorAll('.nav-link');
    
    // Add active class to matching link
    navLinks.forEach(link => {
      const linkPath = new URL(link.href).pathname;
      
      // Exact match for root path
      if (currentPath === linkPath) {
        link.classList.add('active');
        link.closest('.nav-item')?.classList.add('active');
      }
      // Special handling for course-related paths
      else if (linkPath === '/courses') {
        // Activate "Courses" link for all course pages except instructor/student dashboards
        if (currentPath.startsWith('/courses') && 
            !currentPath.startsWith('/courses/instructor/dashboard') && 
            !currentPath.startsWith('/courses/student/dashboard')) {
          link.classList.add('active');
          link.closest('.nav-item')?.classList.add('active');
        }
      }
      // Instructor dashboard paths
      else if (linkPath === '/courses/instructor/dashboard' && currentPath.startsWith('/courses/instructor/dashboard')) {
        link.classList.add('active');
        link.closest('.nav-item')?.classList.add('active');
      }
      // Student dashboard paths
      else if (linkPath === '/courses/student/dashboard' && currentPath.startsWith('/courses/student/dashboard')) {
        link.classList.add('active');
        link.closest('.nav-item')?.classList.add('active');
      }
      // Other nested routes (but not course-related)
      else if (linkPath !== '/' && linkPath !== '/courses' && currentPath.startsWith(linkPath)) {
        link.classList.add('active');
        link.closest('.nav-item')?.classList.add('active');
      }
    });
    const mobileToggler = document.getElementById('mobileMenuToggler');
    const mobileSidebar = document.getElementById('mobileSidebar');
    const mobileOverlay = document.getElementById('mobileOverlay');
    const closeBtn = document.getElementById('closeMobileMenu');
    const body = document.body;
    
    function openMobileMenu() {
      mobileSidebar.classList.add('active');
      mobileOverlay.classList.add('active');
      body.classList.add('menu-open');
    }

    function closeMobileMenu() {
      mobileSidebar.classList.remove('active');
      mobileOverlay.classList.remove('active');
      body.classList.remove('menu-open');
    }

    // Open menu
    if (mobileToggler) {
      mobileToggler.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        openMobileMenu();
      });
    }

    // Close menu with close button
    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        closeMobileMenu();
      });
    }

    // Close menu when clicking overlay
    if (mobileOverlay) {
      mobileOverlay.addEventListener('click', function() {
        closeMobileMenu();
      });
    }

    // Close menu when clicking nav links
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', function() {
        // Small delay to allow navigation
        setTimeout(closeMobileMenu, 100);
      });
    });

    // Close menu when clicking auth buttons
    document.querySelectorAll('.mobile-auth-buttons .btn').forEach(btn => {
      btn.addEventListener('click', function() {
        setTimeout(closeMobileMenu, 100);
      });
    });

    // Handle window resize
    window.addEventListener('resize', function() {
      if (window.innerWidth >= 992 && body.classList.contains('menu-open')) {
        closeMobileMenu();
      }
    });

    // Navbar scroll effect
    const navbar = document.getElementById('mainNavbar');
    if (navbar) {
      function updateNavbar() {
        if (window.scrollY > 50) {
          navbar.classList.add('navbar-scrolled');
        } else {
          navbar.classList.remove('navbar-scrolled');
        }
      }
      
      updateNavbar();
      window.addEventListener('scroll', updateNavbar);
    }

    // Theme Toggle Functionality (Dropdown + Mobile)
    const themeToggles = document.querySelectorAll('#themeToggle, #mobileThemeToggle');
    
    themeToggles.forEach(themeToggle => {
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          document.body.classList.toggle('dark-theme');
          
          // Update all theme toggle icons
          const allThemeIcons = document.querySelectorAll('#themeToggle i, #mobileThemeToggle i');
          
          if (document.body.classList.contains('dark-theme')) {
            // Switch to dark mode
            localStorage.setItem('theme', 'dark');
            allThemeIcons.forEach(icon => {
              icon.classList.replace('fa-moon', 'fa-sun');
            });
            // Update button text
            document.querySelectorAll('#themeToggle').forEach(btn => {
              btn.innerHTML = '<i class="fa-solid fa-sun me-2"></i> Light Mode';
            });
            document.querySelectorAll('#mobileThemeToggle').forEach(btn => {
              btn.innerHTML = '<i class="fa-solid fa-sun"></i> Light Mode';
            });
          } else {
            // Switch to light mode
            localStorage.setItem('theme', 'light');
            allThemeIcons.forEach(icon => {
              icon.classList.replace('fa-sun', 'fa-moon');
            });
            // Update button text
            document.querySelectorAll('#themeToggle').forEach(btn => {
              btn.innerHTML = '<i class="fa-solid fa-moon me-2"></i> Dark Mode';
            });
            document.querySelectorAll('#mobileThemeToggle').forEach(btn => {
              btn.innerHTML = '<i class="fa-solid fa-moon"></i> Dark Mode';
            });
          }
        });
      }
    });
    
    // Initialize theme on page load
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'dark') {
      document.body.classList.add('dark-theme');
      // Update all theme toggle icons and text for dark mode
      document.querySelectorAll('#themeToggle i, #mobileThemeToggle i').forEach(icon => {
        icon.classList.replace('fa-moon', 'fa-sun');
      });
      document.querySelectorAll('#themeToggle').forEach(btn => {
        btn.innerHTML = '<i class="fa-solid fa-sun me-2"></i> Light Mode';
      });
      document.querySelectorAll('#mobileThemeToggle').forEach(btn => {
        btn.innerHTML = '<i class="fa-solid fa-sun"></i> Light Mode';
      });
    }
  });
</script>