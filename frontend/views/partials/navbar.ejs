<!-- Navbar Styling - Centralized -->
<style>
/* Consistent Navbar Sizing - All Pages */
#mainNavbar {
  min-height: 70px !important;
  max-height: 70px !important;
  height: 70px !important;
  transition: all 0.3s ease !important;
}

/* Navbar container sizing */
#mainNavbar .container {
  min-height: 70px !important;
  display: flex !important;
  align-items: center !important;
}

/* Navbar brand sizing */
#mainNavbar .navbar-brand {
  min-height: 50px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Navbar nav sizing */
#mainNavbar .navbar-nav {
  min-height: 50px !important;
  display: flex !important;
  align-items: center !important;
}

/* Navbar links sizing */
#mainNavbar .nav-link {
  min-height: 40px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Navbar buttons sizing */
#mainNavbar .btn {
  min-height: 38px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Spacer for fixed-top - Consistent across all pages */
.navbar-spacer {
  height: 70px !important;
  width: 100% !important;
  display: block !important;
}

/* Mobile responsive adjustments */
@media (max-width: 768px) {
  #mainNavbar {
    min-height: 60px !important;
    max-height: 60px !important;
    height: 60px !important;
  }
  
  .navbar-spacer {
    height: 60px !important;
  }
}

/* Light Mode Navbar */
.navbar.bg-blur {
  background: rgba(255, 255, 255, 0.85) !important;
  backdrop-filter: blur(15px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

/* Dark Mode Navbar */
body.dark-theme nav.navbar,
body.dark-theme .bg-blur {
  background: rgba(15, 15, 15, 0.85) !important;
  backdrop-filter: blur(15px);
  border-bottom: 1px solid #222;
  color: #fff !important;
}

/* Dark Mode Navbar Text Colors */
body.dark-theme .nav-link {
  color: #cfcfcf !important;
  font-weight: 500 !important;
  font-size: 0.95rem !important;
}

body.dark-theme .nav-link:hover {
  color: #7c5bff !important;
}

/* Light Mode Navbar Text Colors */
.navbar.bg-blur .nav-link {
  font-weight: 500 !important;
  font-size: 0.95rem !important;
  color: #333 !important;
}

.navbar.bg-blur .nav-link:hover {
  color: #667eea !important;
}

/* Active State Styling */
.navbar.bg-blur .nav-link.active {
  color: #667eea !important;
  font-weight: 600 !important;
  position: relative;
}

.navbar.bg-blur .nav-link.active::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%);
  width: 30px;
  height: 3px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 2px;
}

/* Dark Mode Active State */
body.dark-theme .nav-link.active {
  color: #9d7dff !important;
  font-weight: 600 !important;
}

body.dark-theme .nav-link.active::after {
  background: linear-gradient(135deg, #9d7dff 0%, #ff71c8 100%);
}

/* Brand Styling */
.navbar-brand {
  color: #333 !important;
  font-weight: 700 !important;
  transition: all 0.3s ease;
}

body.dark-theme .navbar-brand {
  color: #ffffff !important;
}

.navbar-brand:hover {
  transform: translateY(-2px);
}

/* Mobile Menu Toggler */
.navbar-toggler {
  border: none !important;
  padding: 0.25rem 0.5rem;
}

.navbar-toggler:focus {
  box-shadow: none !important;
}

body.dark-theme .navbar-toggler {
  border-color: rgba(255, 255, 255, 0.3) !important;
}

body.dark-theme .navbar-toggler-icon {
  background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 255, 255, 0.8%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
}
</style>

