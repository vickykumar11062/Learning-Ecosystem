<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <style>
    .card {
      border: none;
      border-radius: 10px;
      box-shadow: 0 0 20px rgba(0,0,0,0.1);
    }
    .setting-item {
      border-bottom: 1px solid #eee;
      padding: 1.25rem 0;
    }
    .setting-item:last-child {
      border-bottom: none;
    }
    .setting-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 15px;
      background-color: #f8f9fa;
    }
    .danger-zone {
      border-left: 4px solid #dc3545;
    }
  </style>
</head>
<body class="bg-light">
  <%- include('../partials/navbar', { session }) %>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2>Account Settings</h2>
          <a href="/profile/edit" class="btn btn-outline-primary">
            <i class="fas fa-user-edit me-1"></i> Edit Profile
          </a>
        </div>

        <!-- Display messages -->
        <% if (typeof success_msg !== 'undefined' && success_msg) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
        
        <% if (typeof error_msg !== 'undefined' && error_msg) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>

        <div class="card mb-4">
          <div class="card-body">
            <h5 class="card-title mb-4">Account Information</h5>
            
            <div class="d-flex align-items-center setting-item">
              <div class="setting-icon">
                <i class="fas fa-user text-primary"></i>
              </div>
              <div class="flex-grow-1">
                <h6 class="mb-0">Name</h6>
                <p class="text-muted mb-0"><%= user.name %></p>
              </div>
            </div>

            <div class="d-flex align-items-center setting-item">
              <div class="setting-icon">
                <i class="fas fa-envelope text-primary"></i>
              </div>
              <div class="flex-grow-1">
                <h6 class="mb-0">Email</h6>
                <p class="text-muted mb-0"><%= user.email %></p>
              </div>
            </div>

            <% if (user.phone) { %>
            <div class="d-flex align-items-center setting-item">
              <div class="setting-icon">
                <i class="fas fa-phone text-primary"></i>
              </div>
              <div class="flex-grow-1">
                <h6 class="mb-0">Phone</h6>
                <p class="text-muted mb-0"><%= user.phone %></p>
              </div>
            </div>
            <% } %>

            <div class="d-flex align-items-center setting-item">
              <div class="setting-icon">
                <i class="fas fa-user-shield text-primary"></i>
              </div>
              <div class="flex-grow-1">
                <h6 class="mb-0">Account Type</h6>
                <p class="text-muted mb-0 text-capitalize"><%= user.role %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Danger Zone -->
        <div class="card border-danger">
          <div class="card-body danger-zone">
            <h5 class="card-title text-danger mb-4">
              <i class="fas fa-exclamation-triangle me-2"></i>Danger Zone
            </h5>
            
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="mb-1">Delete Account</h6>
                <p class="text-muted small mb-0">
                  Once you delete your account, there is no going back. Please be certain.
                </p>
              </div>
              <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                <i class="far fa-trash-alt me-1"></i> Delete Account
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Account Modal -->
  <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-danger" id="deleteAccountModalLabel">
            <i class="fas fa-exclamation-triangle me-2"></i>Delete Account
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/profile/delete-account" method="POST" id="deleteAccountForm">
          <div class="modal-body">
            <p>Are you sure you want to delete your account? This action cannot be undone.</p>
            <p class="fw-bold">This will permanently:</p>
            <ul>
              <li>Delete your profile and all associated data</li>
              <li>Remove you from all courses</li>
              <li>Delete your learning progress and certificates</li>
            </ul>
            <div class="mb-3">
              <label for="confirmEmail" class="form-label">
                To confirm, type your email <strong><%= user.email %></strong> below:
              </label>
              <input type="email" class="form-control" id="confirmEmail" name="confirmEmail" required>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger" id="confirmDeleteBtn">
              <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
              <span class="btn-text">Yes, delete my account</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    // Handle delete account form submission
    document.addEventListener('DOMContentLoaded', function() {
      const deleteForm = document.getElementById('deleteAccountForm');
      const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
      const confirmEmailInput = document.getElementById('confirmEmail');
      const userEmail = '<%= user.email %>';

      if (deleteForm) {
        deleteForm.addEventListener('submit', function(e) {
          e.preventDefault();
          
          if (confirmEmailInput.value !== userEmail) {
            alert('Email does not match. Please type your email correctly.');
            return;
          }

          const spinner = confirmDeleteBtn.querySelector('.spinner-border');
          const btnText = confirmDeleteBtn.querySelector('.btn-text');
          
          // Show loading state
          spinner.classList.remove('d-none');
          btnText.textContent = 'Deleting...';
          confirmDeleteBtn.disabled = true;
          
          // Submit the form
          this.submit();
        });
      }
    });

    // Theme Toggle Functionality
    const savedTheme = localStorage.getItem('theme');
    const themeIcon = document.getElementById('theme-icon');
    
    if (savedTheme === 'dark') {
      document.body.classList.add('dark-theme');
      if (themeIcon) {
        themeIcon.classList.replace('fa-moon', 'fa-sun');
      }
    }

    // Theme toggle functionality
    const themeToggle = document.getElementById('theme-toggle');
    const mobileThemeToggles = document.querySelectorAll('#mobileThemeToggle');
    
    if (themeToggle && themeIcon) {
      themeToggle.addEventListener('click', () => {
        document.body.classList.toggle('dark-theme');
        
        if (document.body.classList.contains('dark-theme')) {
          themeIcon.classList.replace('fa-moon', 'fa-sun');
          localStorage.setItem('theme', 'dark');
        } else {
          themeIcon.classList.replace('fa-sun', 'fa-moon');
          localStorage.setItem('theme', 'light');
        }
      });
    }

    // Mobile theme toggles
    mobileThemeToggles.forEach(mobileThemeToggle => {
      if (mobileThemeToggle) {
        mobileThemeToggle.addEventListener('click', () => {
          document.body.classList.toggle('dark-theme');
          
          if (themeIcon) {
            if (document.body.classList.contains('dark-theme')) {
              themeIcon.classList.replace('fa-moon', 'fa-sun');
              localStorage.setItem('theme', 'dark');
            } else {
              themeIcon.classList.replace('fa-sun', 'fa-moon');
              localStorage.setItem('theme', 'light');
            }
          } else {
            // Fallback for mobile menu icon
            const mobileIcon = mobileThemeToggle.querySelector('i');
            if (mobileIcon) {
              if (document.body.classList.contains('dark-theme')) {
                mobileIcon.classList.replace('fa-moon', 'fa-sun');
                localStorage.setItem('theme', 'dark');
              } else {
                mobileIcon.classList.replace('fa-sun', 'fa-moon');
                localStorage.setItem('theme', 'light');
              }
            }
          }
        });
      }
    });
  </script>
</body>
</html>
