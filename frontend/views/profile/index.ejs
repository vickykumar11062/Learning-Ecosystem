<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'My Profile' %> - EduLearn</title>
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      min-height: 100vh;
      padding-bottom: 3rem;
    }

    /* Page Header */
    .page-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 2.5rem 0;
      margin-bottom: 2rem;
      box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
    }

    .page-header h1 {
      color: white;
      font-size: 2rem;
      font-weight: 700;
      margin: 0;
    }

    /* Profile Card */
    .profile-card {
      background: white;
      border-radius: 10px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      margin-top: -60px;
      position: relative;
      z-index: 1;
    }

    /* Avatar Section */
    .avatar-section {
      text-align: center;
      padding: 2rem 0;
      background: linear-gradient(135deg, #f5f7fa 0%, #e2e8f0 100%);
      border-bottom: 1px solid #e2e8f0;
    }

    .avatar-wrapper {
      position: relative;
      display: inline-block;
      margin-bottom: 1.5rem;
    }

    .avatar-preview {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      background: #fff;
      border: 5px solid #fff;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      margin: 0 auto;
    }

    .avatar-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .avatar-preview i {
      font-size: 4rem;
      color: #94a3b8;
      line-height: 140px;
    }

    /* Profile Info */
    .profile-info {
      text-align: center;
      padding: 0 1.5rem;
    }

    .profile-name {
      font-size: 1.75rem;
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.5rem;
    }

    .profile-role {
      display: inline-block;
      background: #e0f2fe;
      color: #0369a1;
      padding: 0.25rem 1rem;
      border-radius: 20px;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      text-transform: capitalize;
    }

    .profile-bio {
      color: #475569;
      line-height: 1.7;
      max-width: 700px;
      margin: 0 auto 2rem;
      font-size: 1.05rem;
    }

    /* Profile Section */
    .profile-section {
      padding: 2rem;
      border-bottom: 1px solid #e2e8f0;
    }

    .section-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #e2e8f0;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .section-title i {
      color: #667eea;
      font-size: 1.1em;
    }

    /* Info Items */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .info-item {
      margin-bottom: 1.25rem;
    }

    .info-label {
      font-weight: 600;
      color: #64748b;
      margin-bottom: 0.25rem;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .info-label i {
      color: #94a3b8;
      width: 20px;
      text-align: center;
    }

    .info-value {
      color: #1e293b;
      font-size: 1.05rem;
      font-weight: 500;
      word-break: break-word;
    }

    /* Social Icons */
    .social-links {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    .social-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #f1f5f9;
      color: #64748b;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .social-icon:hover {
      background: #e2e8f0;
      transform: translateY(-2px);
      color: #4f46e5;
    }

    /* Edit Button */
    .edit-profile-btn {
      position: absolute;
      top: 2rem;
      right: 2rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: #4f46e5;
      color: white;
      padding: 0.5rem 1.25rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.3s ease;
      box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.1), 0 2px 4px -1px rgba(79, 70, 229, 0.06);
    }

    .edit-profile-btn:hover {
      background: #4338ca;
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.1), 0 4px 6px -2px rgba(79, 70, 229, 0.05);
      color: white;
    }

    /* Instructor Badge */
    .instructor-badge {
      background: #f0f9ff;
      color: #0369a1;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      margin-left: 0.5rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .page-header {
        padding: 1.5rem 0;
        text-align: center;
      }

      .page-header h1 {
        font-size: 1.5rem;
      }

      .profile-card {
        margin-top: -40px;
      }

      .avatar-preview {
        width: 120px;
        height: 120px;
      }

      .avatar-preview i {
        font-size: 3rem;
        line-height: 110px;
      }

      .profile-name {
        font-size: 1.5rem;
      }

      .edit-profile-btn {
        position: static;
        margin: 1rem auto;
        display: flex;
        justify-content: center;
        width: auto;
        max-width: 200px;
      }

      .info-grid {
        grid-template-columns: 1fr;
      }
    }

    /* 🌙 DARK MODE STYLING FOR PROFILE PAGE */
    body.dark-theme {
      background: #0e0e0e !important;
      color: #e6e6e6 !important;
      transition: background 0.3s ease, color 0.3s ease;
    }

    /* Dark Page Header */
    body.dark-theme .page-header {
      background: radial-gradient(circle at top left, #141414 0%, #0d0d0d 40%, #000000 90%) !important;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5) !important;
    }

    body.dark-theme .page-header h1 {
      color: #ffffff !important;
      font-weight: 800;
      background: linear-gradient(135deg, #9d7dff 0%, #ff71c8 50%, #ffd86b 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 1px;
      text-shadow: 0 0 30px rgba(146, 110, 255, 0.4);
    }

    /* Dark Profile Card */
    body.dark-theme .profile-card {
      background: #1a1a1a !important;
      border: 1px solid #333 !important;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5) !important;
    }

    /* Dark Avatar Section */
    body.dark-theme .avatar-section {
      background: linear-gradient(135deg, #1f1f1f 0%, #2a2a2a 100%) !important;
      border-bottom-color: #333 !important;
    }

    body.dark-theme .avatar-preview {
      background: #0f0f0f !important;
      border-color: #333 !important;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3) !important;
    }

    body.dark-theme .avatar-preview i {
      color: #6b7280 !important;
    }

    /* Dark Profile Info */
    body.dark-theme .profile-name {
      color: #ffffff !important;
    }

    body.dark-theme .profile-email {
      color: #bfbfbf !important;
    }

    body.dark-theme .profile-bio {
      color: #dcdcdc !important;
    }

    /* Dark Instructor Badge */
    body.dark-theme .instructor-badge {
      background: rgba(124, 91, 255, 0.2) !important;
      color: #9b87ff !important;
    }

    /* Dark Profile Sections */
    body.dark-theme .profile-section {
      background: #1f1f1f !important;
      border-color: #333 !important;
    }

    body.dark-theme .section-title {
      color: #ffffff !important;
      font-weight: 700;
      background: linear-gradient(135deg, #9d7dff, #ff71c8, #ffd86b);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 35px rgba(146, 110, 255, 0.25);
    }

    body.dark-theme .section-title i {
      color: #9b87ff !important;
    }

    /* Dark Info Items */
    body.dark-theme .info-item {
      background: #1a1a1a !important;
      border-color: #333 !important;
    }

    body.dark-theme .info-label {
      color: #bfbfbf !important;
    }

    body.dark-theme .info-label i {
      color: #9b87ff !important;
    }

    body.dark-theme .info-value {
      color: #e6e6e6 !important;
    }

    body.dark-theme .info-value strong {
      color: #ffffff !important;
    }

    body.dark-theme .info-value p {
      color: #dcdcdc !important;
    }

    /* Dark Social Links */
    body.dark-theme .social-links {
      background: #1a1a1a !important;
      border-color: #333 !important;
    }

    body.dark-theme .social-icon {
      background: rgba(255, 255, 255, 0.1) !important;
      border-color: rgba(255, 255, 255, 0.2) !important;
      color: #cfcfcf !important;
    }

    body.dark-theme .social-icon:hover {
      background: rgba(124, 91, 255, 0.3) !important;
      color: #ffffff !important;
      box-shadow: 0 0 30px rgba(124, 91, 255, 0.5) !important;
    }

    /* Dark Edit Button */
    body.dark-theme .edit-profile-btn {
      background: linear-gradient(135deg, #9d7dff, #ff71c8) !important;
      box-shadow: 0 4px 6px -1px rgba(157, 125, 255, 0.3), 0 2px 4px -1px rgba(157, 125, 255, 0.2) !important;
    }

    body.dark-theme .edit-profile-btn:hover {
      background: linear-gradient(135deg, #7c5bff, #ff51c8) !important;
      box-shadow: 0 10px 15px -3px rgba(157, 125, 255, 0.4), 0 4px 6px -2px rgba(157, 125, 255, 0.3) !important;
    }

    /* Dark Stats */
    body.dark-theme .stats-grid {
      background: #1a1a1a !important;
      border-color: #333 !important;
    }

    body.dark-theme .stat-item {
      border-color: #333 !important;
    }

    body.dark-theme .stat-number {
      color: #ffffff !important;
      background: none !important;
      -webkit-text-fill-color: #ffffff !important;
      text-shadow: 0 0 20px rgba(124, 91, 255, 0.5);
    }

    body.dark-theme .stat-label {
      color: #bfbfbf !important;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center">
        <h1><%= title || 'My Profile' %></h1>
        <a href="<%= isOwnProfile ? '/courses' : '/courses/instructor/earnings' %>" class="btn btn-light">
          <i class="fas fa-arrow-left me-2"></i> Back to <%= isOwnProfile ? 'Courses' : 'Earnings' %>
        </a>
      </div>
    </div>
  </div>

  <!-- Profile Card -->
  <div class="container">
    <div class="profile-card">
      <!-- Edit Profile Button (only show on own profile) -->
      <% if (isOwnProfile) { %>
        <a href="/profile/edit" class="edit-profile-btn">
          <i class="fas fa-edit"></i> Edit Profile
        </a>
      <% } %>
      
      <!-- Avatar Section -->
      <div class="avatar-section">
        <div class="avatar-wrapper">
          <div class="avatar-preview">
            <% if (user.role === 'instructor' && user.avatar && user.avatar.url) { %>
              <img src="<%= user.avatar.url %>" alt="<%= user.name %>" id="avatarImage">
            <% } else { %>
              <i class="fa-solid fa-user"></i>
            <% } %>
          </div>
        </div>
        
        <div class="profile-info">
          <h1 class="profile-name">
            <%= user.name %>
            <% if (user.role === 'instructor') { %>
              <span class="instructor-badge">
                <i class="fas fa-chalkboard-teacher"></i> Instructor
              </span>
            <% } %>
          </h1>
          
          <% if (user.bio) { %>
            <p class="profile-bio"><%= user.bio %></p>
          <% } %>
          
          <!-- Social Links -->
          <% if (user.socialLinks && Object.values(user.socialLinks).some(Boolean)) { %>
            <div class="social-links">
              <% if (user.socialLinks.linkedin) { %>
                <a href="<%= user.socialLinks.linkedin %>" target="_blank" class="social-icon" title="LinkedIn">
                  <i class="fab fa-linkedin-in"></i>
                </a>
              <% } %>
              
              <% if (user.socialLinks.twitter) { %>
                <a href="<%= user.socialLinks.twitter %>" target="_blank" class="social-icon" title="Twitter">
                  <i class="fab fa-twitter"></i>
                </a>
              <% } %>
              
              <% if (user.socialLinks.github) { %>
                <a href="<%= user.socialLinks.github %>" target="_blank" class="social-icon" title="GitHub">
                  <i class="fab fa-github"></i>
                </a>
              <% } %>
              
              <% if (user.socialLinks.website) { %>
                <a href="<%= user.socialLinks.website %>" target="_blank" class="social-icon" title="Website">
                  <i class="fas fa-globe"></i>
                </a>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
      
      <!-- Contact Information -->
      <div class="profile-section">
        <h3 class="section-title">
          <i class="fas fa-id-card"></i>
          Contact Information
        </h3>
        
        <div class="info-grid">
          <div class="info-item">
            <div class="info-label">
              <i class="fas fa-envelope"></i>
              Email Address
            </div>
            <div class="info-value"><%= user.email %></div>
          </div>
          
          <% if (user.phone) { %>
            <div class="info-item">
              <div class="info-label">
                <i class="fas fa-phone"></i>
                Phone Number
              </div>
              <div class="info-value"><%= user.phone %></div>
            </div>
          <% } %>
          
          <% if (user.address || user.city || user.country) { %>
            <div class="info-item">
              <div class="info-label">
                <i class="fas fa-map-marker-alt"></i>
                Location
              </div>
              <div class="info-value"><%= [user.address, user.city, user.country].filter(Boolean).join(', ') %></div>
            </div>
          <% } %>
          
          <% if (user.dateOfBirth) { %>
            <div class="info-item">
              <div class="info-label">
                <i class="fas fa-birthday-cake"></i>
                Date of Birth
              </div>
              <div class="info-value">
                <%= new Date(user.dateOfBirth).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
      
      <!-- Instructor Information -->
      <% if (user.role === 'instructor' && (user.expertise || user.experience || user.teachingPhilosophy)) { %>
        <div class="profile-section">
          <h3 class="section-title">
            <i class="fas fa-chalkboard-teacher"></i>
            Instructor Information
          </h3>
          
          <div class="info-grid">
            <% if (user.expertise) { %>
              <div class="info-item">
                <div class="info-label">
                  <i class="fas fa-star"></i>
                  Expertise
                </div>
                <div class="info-value"><%= user.expertise %></div>
              </div>
            <% } %>
            
            <% if (user.experience) { %>
              <div class="info-item">
                <div class="info-label">
                  <i class="fas fa-briefcase"></i>
                  Experience
                </div>
                <div class="info-value">
                  <%= user.experience %> <%= user.experience === 1 ? 'year' : 'years' %> of experience
                </div>
              </div>
            <% } %>
            
            <% if (user.teachingPhilosophy) { %>
              <div class="info-item" style="grid-column: 1 / -1">
                <div class="info-label">
                  <i class="fas fa-graduation-cap"></i>
                  Teaching Philosophy
                </div>
                <div class="info-value">
                  <p class="mb-0"><%= user.teachingPhilosophy %></p>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>
      
      <!-- Student Information -->
      <% if (user.role === 'student' && user.enrolledCourses && user.enrolledCourses.length > 0) { %>
        <div class="profile-section">
          <h3 class="section-title">
            <i class="fas fa-book"></i>
            My Learning
          </h3>
          
          <div class="info-item">
            <div class="info-label">
              <i class="fas fa-graduation-cap"></i>
              Enrolled Courses
            </div>
            <div class="info-value">
              <%= user.enrolledCourses.length %> <%= user.enrolledCourses.length === 1 ? 'course' : 'courses' %> enrolled
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    // Theme Toggle Functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Initialize theme from localStorage
      const savedTheme = localStorage.getItem('theme');
      const themeIcon = document.getElementById('theme-icon');
      
      if (savedTheme === 'dark') {
        document.body.classList.add('dark-theme');
        if (themeIcon) {
          themeIcon.classList.replace('fa-moon', 'fa-sun');
        }
      }

      // Theme toggle functionality
      const themeToggle = document.getElementById('theme-toggle');
      const mobileThemeToggles = document.querySelectorAll('#mobileThemeToggle');
      
      if (themeToggle && themeIcon) {
        themeToggle.addEventListener('click', () => {
          document.body.classList.toggle('dark-theme');
          
          if (document.body.classList.contains('dark-theme')) {
            themeIcon.classList.replace('fa-moon', 'fa-sun');
            localStorage.setItem('theme', 'dark');
          } else {
            themeIcon.classList.replace('fa-sun', 'fa-moon');
            localStorage.setItem('theme', 'light');
          }
        });
      }

      // Mobile theme toggles
      mobileThemeToggles.forEach(mobileThemeToggle => {
        if (mobileThemeToggle) {
          mobileThemeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark-theme');
            
            if (themeIcon) {
              if (document.body.classList.contains('dark-theme')) {
                themeIcon.classList.replace('fa-moon', 'fa-sun');
                localStorage.setItem('theme', 'dark');
              } else {
                themeIcon.classList.replace('fa-sun', 'fa-moon');
                localStorage.setItem('theme', 'light');
              }
            } else {
              // Fallback for mobile menu icon
              const mobileIcon = mobileThemeToggle.querySelector('i');
              if (mobileIcon) {
                if (document.body.classList.contains('dark-theme')) {
                  mobileIcon.classList.replace('fa-moon', 'fa-sun');
                  localStorage.setItem('theme', 'dark');
                } else {
                  mobileIcon.classList.replace('fa-sun', 'fa-moon');
                  localStorage.setItem('theme', 'light');
                }
              }
            }
          });
        }
      });
    });
  </script>
</body>
</html>
