<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>505 - HTTP Version Not Supported</title>
</head>
<body class="bg-light d-flex flex-column min-vh-100">
  <%- include('../partials/navbar') %>

  <div class="container text-center my-auto py-5">
    <h1 class="display-1 fw-bold text-danger">505</h1>
    <h3 class="mb-3 text-dark">HTTP Version Not Supported</h3>
    <p class="lead mb-4 text-secondary">
      The server does not support the HTTP protocol version used in your request.
    </p>
    <div class="d-flex justify-content-center gap-3">
      <a href="/" class="btn btn-primary">
        <i class="fa fa-home me-2"></i> Go Home
      </a>
      <button onclick="window.history.back()" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left me-2"></i> Go Back
      </button>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
