<%- include('partials/head', { title: 'Shipping Policy - EduLearn' }) %>
<%- include('partials/navbar') %>
<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h1 class="mb-4">Shipping Policy</h1>
            
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title text-primary mb-3">Digital Product Delivery</h5>
                    <p class="card-text">
                        All our courses are delivered digitally. Upon successful enrollment and payment, you will receive immediate access to your purchased course(s) in your account dashboard.
                    </p>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title text-primary mb-3">Access Timeframe</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Instant access after purchase</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> 24/7 availability from any device</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Lifetime access to purchased courses</li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title text-primary mb-3">Accessing Your Courses</h5>
                    <p>To access your purchased courses:</p>
                    <ol>
                        <li class="mb-2">Log in to your EduLearn account</li>
                        <li class="mb-2">Go to "My Learning" in your dashboard</li>
                        <li class="mb-2">Click on the course you wish to start</li>
                    </ol>
                    <p>If you encounter any issues accessing your course, please contact our <a href="/contact">support team</a>.</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title text-primary mb-3">Technical Requirements</h5>
                    <p>To ensure the best learning experience, please ensure your device meets these requirements:</p>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="fas fa-laptop me-2"></i> A modern web browser (Chrome, Firefox, Safari, or Edge)</li>
                        <li class="mb-2"><i class="fas fa-wifi me-2"></i> Stable internet connection</li>
                        <li class="mb-2"><i class="fas fa-headphones me-2"></i> Headphones or speakers (for video/audio content)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
