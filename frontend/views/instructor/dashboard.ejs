<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="modern-body">
  <%- include('../partials/navbar') %>


  <!-- Hero Header -->
  <!-- Flash Messages -->
  <div class="flash-messages" style="position: fixed; top: 100px; left: 50%; transform: translateX(-50%); z-index: 9999; width: auto; max-width: 500px; min-width: 300px; padding: 0 15px;">
    <% if (success_msg && success_msg.length > 0) { %>
      <% (Array.isArray(success_msg) ? success_msg : [success_msg]).forEach(function(msg) { %>
        <% if (msg && typeof msg === 'string' && msg.trim() !== '') { %>
          <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert" style="border-radius: 0 !important;">
            <div class="container d-flex justify-content-between align-items-center">
              <div>
                <i class="fas fa-check-circle me-2"></i>
                <%= msg %>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          </div>
        <% } %>
      <% }); %>
    <% } %>
    
    <% if (error_msg && error_msg.length > 0) { %>
      <% (Array.isArray(error_msg) ? error_msg : [error_msg]).forEach(function(msg) { %>
        <% if (msg && typeof msg === 'string' && msg.trim() !== '') { %>
          <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert" style="border-radius: 0 !important;">
            <div class="container d-flex justify-content-between align-items-center">
              <div>
                <i class="fas fa-exclamation-circle me-2"></i>
                <%= msg %>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          </div>
        <% } %>
      <% }); %>
    <% } %>
  </div>

  <section class="hero-section">
    <div class="container">
      <div class="hero-content" style="padding-top: 20px;">
        <div class="hero-icon">
          <i class="fas fa-chalkboard-teacher"></i>
        </div>
        <h1 class="hero-title">Instructor Studio</h1>
        <p class="hero-subtitle">Create, manage, and inspire the next generation of learners</p>
        
        <a href="/courses/instructor/create" class="btn-create">
          <i class="fas fa-plus-circle"></i>
          <span>Create New Course</span>
        </a>

        <div class="stats-row">
          <div class="stat-card">
            <i class="fas fa-layer-group"></i>
            <div>
              <div class="stat-number"><%= courses.length %></div>
              <div class="stat-label">Total Courses</div>
            </div>
          </div>
          <a href="/courses/instructor/earnings" class="stat-card" style="text-decoration: none; color: inherit;">
            <i class="fas fa-chart-line"></i>
            <div>
              <div class="stat-number">Earnings</div>
              <div class="stat-label">View Analytics <i class="fas fa-arrow-right"></i></div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- My Courses -->
  <section class="courses-section">
    <div class="container">
      <% if (courses.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">
            <i class="fas fa-video"></i>
          </div>
          <h3>Start Teaching Today</h3>
          <p>You haven't created any courses yet. Share your knowledge with the world!</p>
          <a href="/courses/instructor/create" class="btn-modern">
            <i class="fas fa-plus-circle me-2"></i>Create Your First Course
          </a>
        </div>
      <% } else { %>
        <div class="section-header">
          <h2><i class="fas fa-layer-group me-2"></i>My Courses</h2>
          <p>Manage and update your course content</p>
        </div>

        <div class="courses-grid">
          <% courses.forEach(course => { %>
            <div class="course-card">
              <div class="course-image-wrapper">
                <img src="<%= course.thumbnail.url %>" class="course-image" alt="<%= course.title %>">
                <div class="course-overlay">
                  <div class="instructor-badge">
                    <i class="fas fa-crown"></i>
                    <span>Your Course</span>
                  </div>
                </div>
              </div>

              <div class="course-content">
                <h3 class="course-title"><%= course.title %></h3>
                
                <div class="course-meta">
                  <div class="meta-item">
                    <i class="fas fa-calendar"></i>
                    <span><%= course.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                  <div class="meta-item price">
                    <i class="fas fa-tag"></i>
                    <span>₹<%= course.price %></span>
                  </div>
                </div>

                <div class="actions-grid">
                  <div class="d-flex flex-wrap gap-2">
                    <a href="/upload/<%= course._id %>" class="action-btn upload flex-grow-1">
                      <i class="fas fa-cloud-upload-alt"></i>
                      <span data-loading-text="Uploading...">Upload</span>
                    </a>
                    
                    <a href="/courses/instructor/edit/<%= course._id %>" class="action-btn edit flex-grow-1">
                      <i class="fas fa-edit"></i>
                      <span data-loading-text="Editing...">Edit</span>
                    </a>
                  </div>
                  
                  <a href="/courses/<%= course.slug %>" class="action-btn view w-100 mt-2">
                    <i class="fas fa-eye"></i>
                    <span>View Course</span>
                  </a>
                  <!-- <button type="button" class="action-btn delete" 
                          onclick="deleteCourse('<%= course._id %>', this)">
                    <i class="fas fa-trash-alt"></i>
                    <span>Delete</span>
                  </button> -->
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <%- include('../partials/footer') %>
  
  <!-- Include the delete modal -->
  <%- include('../partials/delete_modal') %>

  <script>
    // Helper function to show alerts
    function showAlert(type, message) {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type} mt-3 mb-0`;
      alertDiv.role = 'alert';
      alertDiv.innerHTML = message;
      
      const container = document.querySelector('.courses-section .container') || document.body;
      container.prepend(alertDiv);
      
      // Auto-remove after 5 seconds
      setTimeout(() => {
        alertDiv.style.transition = 'opacity 0.5s';
        alertDiv.style.opacity = '0';
        setTimeout(() => alertDiv.remove(), 500);
      }, 5000);
      
      return alertDiv;
    }
    
    // Delete course function
    function deleteCourse(courseId, button) {
      const modal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
      const confirmBtn = document.getElementById('confirmDeleteBtn');
      const originalHandler = confirmBtn.onclick;
      
      confirmBtn.onclick = async function() {
        try {
          const response = await fetch(`/courses/instructor/delete/${courseId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              'X-Requested-With': 'XMLHttpRequest' // Add this header
            },
            credentials: 'same-origin' // Ensure cookies are sent with the request
          });
          
          const contentType = response.headers.get('content-type');
          
          if (contentType && contentType.includes('application/json')) {
            const data = await response.json();
            
            if (!response.ok) {
              throw new Error(data.message || `Server responded with status ${response.status}`);
            }
            
            // Success - remove the course card with animation
            const card = button.closest('.course-card');
            if (card) {
              card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              card.style.opacity = '0';
              card.style.transform = 'scale(0.95)';
              
              setTimeout(() => {
                card.remove();
                showAlert('success', '✅ Course deleted successfully!');
              }, 300);
            } else {
              showAlert('success', '✅ Course deleted successfully!');
              // If card wasn't found, just reload the page to be safe
              setTimeout(() => window.location.reload(), 1000);
            }
            
          } else if (response.redirected) {
            window.location.href = response.url;
            return;
          } else {
            throw new Error('Invalid response from server');
          }
          
        } catch (error) {
          // If we get a 401 or 403, redirect to login
          if (error.message.includes('401') || error.message.includes('403')) {
            window.location.href = '/users/login';
            return;
          }
          showAlert('danger', `❌ Error: ${error.message || 'Failed to delete course'}`);
        } finally {
          // Clean up the handler
          confirmBtn.onclick = originalHandler;
          modal.hide();
        }
      };
      
      // Show the modal
      modal.show();
    }
  </script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    .modern-body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      min-height: 100vh;
      color: #f8fafc;
    }

    /* Hero Section */
    .hero-section {
      background: radial-gradient(ellipse at top right, #10b981 0%, #059669 25%, #047857 50%, #065f46 100%);
      padding: 4rem 0 5rem;
      position: relative;
      overflow: hidden;
    }

    .hero-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
