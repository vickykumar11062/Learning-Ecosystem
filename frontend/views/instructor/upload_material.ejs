<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <!-- Header Section -->
  <div class="bg-primary text-white py-4 mb-4">
    <div class="container">
      <h2 class="mb-0">
        <i class="fa fa-upload me-2"></i>Upload Materials for 
        <span class="fw-bold"><%= course.title %></span>
      </h2>
    </div>
  </div>

  <div class="container pb-5">
    <!-- Upload Form -->
    <div class="row justify-content-center mb-5">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-white border-0 pt-4 pb-3">
            <h4 class="mb-0 fw-semibold">
              <i class="fa fa-plus-circle text-primary me-2"></i>Add New Material
            </h4>
          </div>
          <div class="card-body p-4">
            <form action="/upload/<%= course._id %>" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
              
              <!-- Resource Title -->
              <div class="mb-4">
                <label for="title" class="form-label fw-semibold">
                  <i class="fa fa-heading me-2 text-primary"></i> Resource Title *
                </label>
                <div class="input-group">
                  <input 
                    type="text" 
                    name="title" 
                    id="title"
                    class="form-control form-control-lg" 
                    placeholder="e.g., Lecture 1: Introduction to Programming"
                    required
                    minlength="3"
                    maxlength="200"
                    oninput="updateTitleCount(this)">
                </div>
                <div class="d-flex justify-content-between">
                  <div class="invalid-feedback">
                    Title must be between 3-200 characters.
                  </div>
                  <div class="form-text ms-auto">
                    <span id="titleCharCount">0</span>/200 characters
                  </div>
                </div>
              </div>

              <!-- Description -->
              <div class="mb-4">
                <label for="description" class="form-label fw-semibold">
                  <i class="fa fa-align-left me-2 text-primary"></i> Description
                </label>
                <div class="input-group">
                  <textarea 
                    name="description" 
                    id="description"
                    class="form-control" 
                    rows="4" 
                    placeholder="Describe this resource (optional)..."
                    maxlength="500"
                    oninput="updateDescCount(this)"></textarea>
                </div>
                <div class="d-flex justify-content-between">
                  <div class="form-text ms-auto">
                    <span id="descCharCount">0</span>/500 characters
                  </div>
                </div>
              </div>

              <!-- File Upload -->
              <div class="mb-4">
                <label for="file" class="form-label fw-semibold">
                  <i class="fa fa-file me-2 text-primary"></i> Select File *
                </label>
                <input 
                  type="file" 
                  name="file" 
                  id="file"
                  class="form-control form-control-lg" 
                  accept=".mp4,.pdf,.jpg,.jpeg,.png,.gif"
                  required>
                <div class="invalid-feedback">
                  Please select a valid file.
                </div>
                <div class="form-text mt-2">
                  <i class="fa fa-info-circle me-1"></i>
                  <strong>Supported:</strong> Videos (.mp4), PDFs (.pdf), Images (.jpg, .png, .gif)
                </div>
                <div class="form-text">
                  <strong>Max size:</strong> 100MB
                </div>
                
                <!-- File Info Display -->
                <div id="fileInfo" class="alert alert-info mt-3 d-none">
                  <div class="d-flex align-items-center">
                    <i class="fa fa-file-alt fa-2x me-3"></i>
                    <div>
                      <div class="fw-semibold" id="fileName"></div>
                      <small id="fileSize" class="text-muted"></small>
                    </div>
                  </div>
                </div>
                
                <!-- File Size Warning -->
                <div id="fileSizeWarning" class="alert alert-warning mt-3 d-none">
                  <i class="fa fa-exclamation-triangle me-2"></i>File size exceeds 100MB limit.
                </div>
              </div>

              <!-- Buttons -->
              <div class="d-grid gap-2 d-md-flex justify-content-md-between pt-3">
                <a href="/courses/instructor/dashboard" class="btn btn-outline-secondary btn-lg">
                  <i class="fa fa-arrow-left me-2"></i> Back to Dashboard
                </a>
                <button type="submit" class="btn btn-success btn-lg" id="uploadBtn">
                  <i class="fa fa-cloud-upload-alt me-2"></i> Upload Material
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Uploaded Materials -->
    <% if (course.lessons && course.lessons.length > 0) { %>
      <div class="row">
        <div class="col-12">
          <div class="d-flex align-items-center justify-content-between mb-4">
            <h3 class="fw-bold mb-0">
              <i class="fa fa-list me-2"></i>Uploaded Materials
            </h3>
            <span class="badge bg-primary fs-6"><%= course.lessons.length %> item<%= course.lessons.length !== 1 ? 's' : '' %></span>
          </div>
        </div>
      </div>
      
      <div class="row g-4">
        <% course.lessons.forEach((l, index) => { %>
          <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0 hover-card">
              
              <% if (l.resourceType === 'video') { %>
                <!-- Video Player -->
                <video controls class="w-100 rounded-top" style="max-height: 300px; object-fit: cover; background-color: #000;">
                  <source src="<%= l.resource.url %>" type="video/mp4">
                  Your browser does not support the video tag.
                </video>

              <% } else if (l.resourceType === 'pdf') { %>
                <!-- PDF Viewer -->
                <% 
                  let pdfUrl = l.resource.url;
                  let viewUrl = pdfUrl;
                  let downloadUrl = pdfUrl;
                  
                  if (pdfUrl.includes('cloudinary.com') && pdfUrl.includes('/upload/')) {
                    viewUrl = pdfUrl.replace('/upload/', '/upload/fl_attachment:false/');
                    downloadUrl = pdfUrl.replace('/upload/', '/upload/fl_attachment:true/');
                  }
                %>

                <div class="p-3 bg-light">
                  <div class="ratio ratio-16x9 mb-3">
                    <iframe
                      src="https://docs.google.com/viewer?url=<%= encodeURIComponent(pdfUrl) %>&embedded=true"
                      class="border rounded bg-white"
                      title="<%= l.title %> - PDF Preview"
                      loading="lazy">
                    </iframe>
                  </div>

                  <div class="d-grid gap-2 d-sm-flex">
                    <a href="<%= viewUrl %>" target="_blank" class="btn btn-outline-primary flex-fill">
                      <i class="fa fa-external-link-alt me-2"></i> Open
                    </a>
                    <a href="<%= downloadUrl %>" download class="btn btn-outline-secondary flex-fill">
                      <i class="fa fa-download me-2"></i> Download
                    </a>
                  </div>
                </div>

              <% } else if (l.resourceType === 'image') { %>
                <!-- Image -->
                <img 
                  src="<%= l.resource.url %>" 
                  class="card-img-top" 
                  alt="<%= l.title %>"
                  style="max-height: 300px; object-fit: cover;"
                  loading="lazy">

              <% } else { %>
                <!-- Unsupported -->
                <div class="text-center p-5 bg-light">
                  <i class="fa fa-file fa-3x text-muted mb-3"></i>
                  <p class="text-muted mb-0">Unsupported file type</p>
                </div>
              <% } %>

              <!-- Card Body -->
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h5 class="card-title fw-semibold mb-0">
                    <% if (l.resourceType === 'video') { %>
                      <i class="fa fa-play-circle text-primary me-2"></i>
                    <% } else if (l.resourceType === 'pdf') { %>
                      <i class="fa fa-file-pdf text-danger me-2"></i>
                    <% } else if (l.resourceType === 'image') { %>
                      <i class="fa fa-image text-success me-2"></i>
                    <% } %>
                    <%= l.title %>
                  </h5>
                  <span class="badge bg-secondary">#<%= index + 1 %></span>
                </div>
                
                <p class="card-text text-muted small mb-3">
                  <%= l.description || 'No description provided' %>
                </p>
                
                <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                  <span class="badge bg-light text-dark">
                    <i class="fa fa-file-alt me-1"></i>
                    <%= l.resourceType.toUpperCase() %>
                  </span>
                  
                  <!-- Delete Button (Optional - add delete route if needed) -->
                  <!--
                  <form action="/upload/<%= course._id %>/delete/<%= l._id %>?_method=DELETE" 
                        method="POST" 
                        class="d-inline"
                        onsubmit="return confirm('Are you sure you want to delete this material?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="fa fa-trash me-1"></i> Delete
                    </button>
                  </form>
                  -->
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center py-4 shadow-sm">
        <i class="fa fa-info-circle fa-3x mb-3 d-block text-primary"></i>
        <h5 class="mb-2 fw-semibold">No materials uploaded yet</h5>
        <p class="mb-0 text-muted">Use the form above to add your first resource!</p>
      </div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Bootstrap form validation
    (function() {
      'use strict';
      const form = document.querySelector('.needs-validation');
      
      form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        } else {
          // Show loading state
          const uploadBtn = document.getElementById('uploadBtn');
          uploadBtn.disabled = true;
          uploadBtn.innerHTML = `
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Uploading Material...
          `;
        }
        form.classList.add('was-validated');
      }, false);
    })();

    // Update title character count
    function updateTitleCount(input) {
      const count = input.value.length;
      document.getElementById('titleCharCount').textContent = count;
      
      // Update validation
      if (count < 3 || count > 200) {
        input.setCustomValidity('Title must be between 3-200 characters');
      } else {
        input.setCustomValidity('');
      }
    }
    
    // Update description character count
    function updateDescCount(textarea) {
      const count = textarea.value.length;
      document.getElementById('descCharCount').textContent = count;
    }
    
    // Initialize counts on page load
    document.addEventListener('DOMContentLoaded', function() {
      // Initialize title counter
      const title = document.getElementById('title');
      if (title) {
        updateTitleCount(title);
      }
      
      // Initialize description counter
      const description = document.getElementById('description');
      if (description) {
        updateDescCount(description);
      }
    });

    // Character counter for description
    const descField = document.getElementById('description');
    const descCharCount = document.getElementById('descCharCount');
    
    descField.addEventListener('input', function() {
      descCharCount.textContent = this.value.length;
    });

    // File validation and info display
    const fileInput = document.getElementById('file');
    const fileSizeWarning = document.getElementById('fileSizeWarning');
    const fileInfo = document.getElementById('fileInfo');
    const fileName = document.getElementById('fileName');
    const fileSize = document.getElementById('fileSize');
    const maxSize = 100 * 1024 * 1024; // 100MB

    fileInput.addEventListener('change', function() {
      const file = this.files[0];
      
      if (file) {
        // Display file info
        fileName.textContent = file.name;
        fileSize.textContent = formatFileSize(file.size);
        fileInfo.classList.remove('d-none');
        
        // Validate file size
        if (file.size > maxSize) {
          this.setCustomValidity('File size exceeds 100MB limit');
          fileSizeWarning.classList.remove('d-none');
          fileInfo.classList.add('d-none');
        } else {
          this.setCustomValidity('');
          fileSizeWarning.classList.add('d-none');
        }
      } else {
        fileInfo.classList.add('d-none');
        fileSizeWarning.classList.add('d-none');
      }
    });

    // Format file size helper function
    function formatFileSize(bytes) {
      if (bytes === 0) return '0 Bytes';
      const k = 1024;
      const sizes = ['Bytes', 'KB', 'MB', 'GB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
    }
  </script>

  <style>
    .hover-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .hover-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    
    .card {
      border-radius: 0.75rem;
      overflow: hidden;
    }
    
    .form-control:focus,
    .form-select:focus {
      border-color: #0d6efd;
      box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    
    video {
      background-color: #000;
    }
    
    .card-header {
      border-bottom: 2px solid #f8f9fa;
    }
    
    @media (max-width: 768px) {
      .card-body {
        padding: 1rem !important;
      }
      
      .card-header {
        padding: 1rem !important;
      }
    }
  </style>
</body>
</html>