  </style>
  
  <!-- Add SVG gradient definition -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <linearGradient id="progress-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="var(--brand-1)" />
        <stop offset="100%" stop-color="var(--brand-2)" />
      </linearGradient>
    </defs>
  </svg>

  <!-- Progress Bar Animation Script -->
  <script>
  document.addEventListener("DOMContentLoaded", () => {
    // Animate progress bars smoothly
    document.querySelectorAll(".progress-fill").forEach(fill => {
      const progressValue = fill.getAttribute('data-progress');
      const targetWidth = progressValue + '%';
      fill.style.width = "0";
      setTimeout(() => {
        fill.style.width = targetWidth;
      }, 100);

      // Add glow pulse when completed
      const progress = parseInt(progressValue);
      if (progress >= 100) {
        fill.parentElement.classList.add("completed");
      }
    });

    // Handle completed course glow
    const completedCards = document.querySelectorAll(".completed-card");
    completedCards.forEach(card => {
      card.addEventListener("mouseenter", () => {
        card.style.boxShadow = "0 0 20px rgba(34, 197, 94, 0.4)";
      });
      card.addEventListener("mouseleave", () => {
        card.style.boxShadow = "0 10px 25px rgba(0,0,0,0.2)";
      });
    });
  });
  </script>
</body>
