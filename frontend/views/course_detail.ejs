<% } %>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Hide any existing flash messages first
  hideFlash();
});

    
    // View file function - handles different resource types
    function viewFile(url, resourceType) {
      if (resourceType === 'image') {
        // Open images in new tab
        window.open(url, '_blank');
      } else if (resourceType === 'pdf') {
        // Open PDF in Google Docs viewer in new tab for proper viewing
        const viewerUrl = `https://docs.google.com/viewer?url=${encodeURIComponent(url)}&embedded=false`;
        window.open(viewerUrl, '_blank');
      } else if (resourceType === 'video') {
        // Create a temporary page to view video without downloading
        const videoWindow = window.open('', '_blank');
        videoWindow.document.write(`
          <!DOCTYPE html>
          <html>
          <head>
            <title>Video Player</title>
            <style>
              body {
                margin: 0;
                background: #000;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
              }
              video {
                max-width: 100%;
                max-height: 100vh;
                width: auto;
                height: auto;
              }
            </style>
          </head>
          <body class="">
            <video controls autoplay>
              <source src="${url}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          </body>
          </html>
        `);
        videoWindow.document.close();
      }
    }

    // Download file function - properly handles all file types
    async function downloadFile(url, title, resourceType) {
      try {
        // Fetch the file as blob
        const response = await fetch(url);
        const blob = await response.blob();
        
        // Determine file extension
        let extension = '';
        if (resourceType === 'video') {
          extension = '.mp4'; // Default video extension
          // Try to extract from URL or content-type
          const contentType = response.headers.get('content-type');
          if (contentType) {
            if (contentType.includes('webm')) extension = '.webm';
            else if (contentType.includes('ogg')) extension = '.ogg';
            else if (contentType.includes('mov')) extension = '.mov';
          }
        } else if (resourceType === 'pdf') {
          extension = '.pdf';
        } else if (resourceType === 'image') {
          extension = '.jpg'; // Default image extension
          const contentType = response.headers.get('content-type');
          if (contentType) {
            if (contentType.includes('png')) extension = '.png';
            else if (contentType.includes('gif')) extension = '.gif';
            else if (contentType.includes('webp')) extension = '.webp';
            else if (contentType.includes('svg')) extension = '.svg';
          }
        }
        
        // Create blob URL
        const blobUrl = window.URL.createObjectURL(blob);
        
        // Create download link
        const a = document.createElement('a');
        a.href = blobUrl;
        a.download = (title || 'download') + extension;
        document.body.appendChild(a);
        a.click();
        
        // Cleanup
        document.body.removeChild(a);
        window.URL.revokeObjectURL(blobUrl);
      } catch (error) {
        console.error('Download failed:', error);
        // Fallback to simple download
        const a = document.createElement('a');
        a.href = url;
        a.download = title || 'download';
        a.setAttribute('target', '_blank');
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }
    }

    async function buyCourse(button, courseId, courseTitle) {
  ButtonLoader.show(button, button.dataset.loadingText || "Starting payment...");

  try {
    const res = await fetch("/payment/create-order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ courseId }),
    });

    const data = await res.json();

    if (!data.success || !data.orderId) {
      ButtonLoader.reset(button);
      showFlash(data.message || "Unable to create payment order.", "danger");
      return;
    }

    const options = {
      key: data.key || data.keyId || "<%= process.env.RAZORPAY_KEY_ID %>",
      amount: data.amount,
      currency: data.currency || "INR",
      name: "EduLearn",
      description: courseTitle,
      order_id: data.orderId,
      prefill: {
        name: data.studentName || "",
        email: data.studentEmail || "",
      },
      handler: async function (response) {
        try {
          const verifyRes = await fetch("/payment/verify", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ ...response, courseId }),
          });

          const verifyData = await verifyRes.json();
          if (verifyData.success) {
            showFlash("✅ Payment successful! Redirecting...", "success");
            setTimeout(() => {
              window.location.href =
                verifyData.redirectUrl || "/courses/student/dashboard";
            }, 1200);
          } else {
            ButtonLoader.reset(button);
            showFlash(verifyData.message || "Payment verification failed.", "danger");
          }
        } catch (err) {
          console.error("Verification error:", err);
          ButtonLoader.reset(button);
          showFlash("Error verifying payment.", "danger");
        }
      },
      modal: {
        ondismiss: function () {
          ButtonLoader.reset(button);
          showFlash("Payment window closed.", "warning");
        },
      },
      theme: { color: "#6d8cfb" },
    };

    const rzp = new Razorpay(options);
    rzp.open();
  } catch (e) {
    console.error("Error in buyCourse:", e);
    ButtonLoader.reset(button);
    showFlash("Error starting payment. Please try again.", "danger");
  }
}


    // Delete course function
    function deleteCourse(courseId, button) {
      const modal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
      const confirmBtn = document.getElementById('confirmDeleteBtn');
      const originalHandler = confirmBtn.onclick;
      
      confirmBtn.onclick = async function() {
        try {
          const response = await fetch(`/courses/instructor/delete/${courseId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
          });
          
          const contentType = response.headers.get('content-type');
          
          if (contentType && contentType.includes('application/json')) {
            const data = await response.json();
            
            if (!response.ok) {
              throw new Error(data.message || `Server responded with status ${response.status}`);
            }
            
            // Show success message and redirect
            showFlash('✅ Course deleted successfully!', 'success');
            setTimeout(() => {
              window.location.href = '/courses/instructor/dashboard';
            }, 1500);
            
          } else if (response.redirected) {
            window.location.href = response.url;
            return;
          } else {
            const text = await response.text();
            throw new Error(`Unexpected response format: ${text.substring(0, 100)}...`);
          }
          
        } catch (error) {
          showFlash(`❌ Error: ${error.message || 'Failed to delete course'}`, 'danger');
          
          // If we get a 401 or 403, redirect to login
          if (error.message.includes('401') || error.message.includes('403')) {
            window.location.href = '/users/login';
            return;
          }
        } finally {
          // Clean up the handler
          confirmBtn.onclick = originalHandler;
          modal.hide();
        }
      };
      
      // Show the modal
      modal.show();
    }

    // Delete lesson function
    function deleteLesson(courseId, lessonId, button) {
      const card = button.closest('.card');
      const modal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
      
      // Set up the confirm button handler
      const confirmBtn = document.getElementById('confirmDeleteBtn');
      const originalHandler = confirmBtn.onclick;
      
      confirmBtn.onclick = async function() {
        try {
          const response = await fetch(`/courses/instructor/delete-lesson/${courseId}/${lessonId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            }
          });
          
          if (!response.ok) {
            const error = await response.json();
            throw new Error(error.message || 'Failed to delete lesson');
          }
          
          // Remove the card with a fade out effect
          card.style.transition = 'opacity 0.3s ease';
          card.style.opacity = '0';
          setTimeout(() => {
            card.remove();
            showFlash('✅ Lesson deleted successfully!', 'success');
          }, 300);
          
        } catch (error) {
          showFlash(`❌ Error: ${error.message || 'Failed to delete lesson'}`, 'danger');
        } finally {
          // Clean up the handler
          confirmBtn.onclick = originalHandler;
          modal.hide();
        }
      };
      
      // Show the modal
      modal.show();
    }

    // Soft reveal for cards
    document.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.card');
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) e.target.classList.add('in');
        });
      }, { threshold: 0.12 });
      cards.forEach(c => io.observe(c));
    });
  </script>

<style>
  /* Text truncation for descriptions */
