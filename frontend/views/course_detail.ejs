  /* Animated wave motion */
  @keyframes waveMotion {
    0% { 
      background-position-x: 0;
      opacity: 0.9;
    }
    50% {
      opacity: 1;
    }
    100% { 
      background-position-x: 500px;
      opacity: 0.9;
    }
