    height: 100%;
    background: linear-gradient(90deg, 
      #5a7df4 0%, 
      #8a4ff6 50%,
      #b84ff6 100%);
    clip-path: none; /* Remove wave clip for left-to-right fill */
    transition: width 1s cubic-bezier(0.25, 0.1, 0.15, 1);
    background-size: 200% 100%;
    animation: waveMotion 6s linear infinite;
    box-shadow: 0 0 10px rgba(138, 79, 246, 0.5);
