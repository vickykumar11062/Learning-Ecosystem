  <!-- PDF.js Library -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
  <script>
    // Initialize PDF.js
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';
    
    // Handle PDF preview
    document.addEventListener('DOMContentLoaded', function() {
      const pdfPreviews = document.querySelectorAll('.pdf-preview');
      
      pdfPreviews.forEach(preview => {
        const pdfUrl = preview.getAttribute('data-pdf-url');
        const canvas = preview.querySelector('.pdf-canvas');
        const ctx = canvas.getContext('2d');
        let pdf = null;
        let isRendered = false;
        
        // Function to render PDF preview
        const renderPdfPreview = () => {
          if (isRendered) return;
          
          pdfjsLib.getDocument(pdfUrl).promise.then(pdfDoc => {
            return pdfDoc.getPage(1);
          }).then(page => {
            const viewport = page.getViewport({ scale: 1.0 });
            const container = preview.getBoundingClientRect();
            const padding = 20;
            const availableWidth = container.width - (padding * 2);
            const availableHeight = container.height - (padding * 2);
            const scale = Math.min(
              availableWidth / viewport.width,
              availableHeight / viewport.height
            );
            
            const scaledViewport = page.getViewport({ scale });
            
            canvas.width = scaledViewport.width;
            canvas.height = scaledViewport.height;
            
            const renderContext = {
              canvasContext: ctx,
              viewport: scaledViewport
            };
            
            return page.render(renderContext).promise.then(() => {
              isRendered = true;
              canvas.style.opacity = '1';
              canvas.style.transform = 'scale(1)';
            });
          }).catch(error => {
            throw new Error('Error rendering PDF preview:', error);
          });
        };
        
        // Handle hover events
        preview.addEventListener('mouseenter', () => {
          if (!isRendered) {
            renderPdfPreview();
          } else {
            const canvas = preview.querySelector('.pdf-canvas');
            canvas.style.opacity = '1';
            canvas.style.transform = 'scale(1)';
          }
        });
        
        // Close button
        const closeBtn = preview.querySelector('.pdf-close');
        closeBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const overlay = preview.querySelector('.pdf-preview-overlay');
          overlay.style.opacity = '0';
          overlay.style.visibility = 'hidden';
          
          // Reset icon
          const icon = preview.querySelector('.pdf-icon');
          icon.style.opacity = '1';
          icon.style.visibility = 'visible';
        });
      });
    });
  </script>



