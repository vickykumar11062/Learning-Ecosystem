  <!-- Progress handling and auto-refresh -->
  <!-- Duplicate Progress Script Removed -->
  <!-- This functionality is now handled in the main progress script below -->

  <!-- Hero Progress Management -->
  <!-- Now using applyOverallProgress function below -->
  
  <script>
  // Declare all variables from EJS at the top
  const courseId = "<%= course._id %>";
  const serverProgress = <%- JSON.stringify((typeof progressPercent !== 'undefined' && progressPercent != null) ? progressPercent : 0) %>;
  
  function applyOverallProgress(overallProgress) {
    overallProgress = Math.min(100, Math.max(0, parseInt(overallProgress, 10) || 0));
    document.querySelectorAll('.wave-fill').forEach(w => {
      w.style.width = overallProgress + '%';
    });
    const label = document.querySelector('#main-progress-value');
    if (label) {
      label.textContent = overallProgress >= 100 ? 'Course Completed' : `Continue Learning — ${overallProgress}%`;
    }
    // update data-progress attribute on main button so CSS rules apply
    const mainBtn = document.querySelector('.progress-btn');
    if (mainBtn) mainBtn.setAttribute('data-progress', overallProgress);
  }

  async function fetchOverallProgress() {
    try {
      const res = await fetch("/progress/overall/<%= course._id %>");
      const data = await res.json();
      if (data.success) {
        applyOverallProgress(data.overallProgress);
        
        // update localStorage fallback
        localStorage.setItem(`courseProgress_<%= course._id %>`, data.overallProgress);
        localStorage.setItem(`courseProgress_<%= course._id %>_ts`, Date.now());
      }
    } catch (err) {
      console.warn("Failed to refresh overall progress:", err);
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    // Always sync fresh progress with server
    fetchOverallProgress();

    // Sync overall progress if viewer updated in another tab/window
window.addEventListener('storage', (ev) => {
  if (ev.key === `courseProgress_<%= course._id %>` ||
      ev.key === `courseProgress_<%= course._id %>_ts`) {
    const updated = localStorage.getItem(`courseProgress_<%= course._id %>`);
    if (updated !== null) applyOverallProgress(updated);
  }
});

// Also sync when user returns to the page
window.addEventListener('focus', () => {
  const saved = localStorage.getItem(`courseProgress_<%= course._id %>`);
  if (saved !== null) applyOverallProgress(saved);
});

// Also sync when page becomes visible again
document.addEventListener('visibilitychange', () => { 
  if (document.visibilityState === 'visible') {
    const saved = localStorage.getItem(`courseProgress_<%= course._id %>`);
    if (saved !== null) applyOverallProgress(saved);
  }
});

    // Handle progress updates from viewer (iframe or new-tab)
window.addEventListener("message", (event) => {
    if (!event.data || event.data.type !== "progressUpdate") return;

    const { lessonId, progress, overallProgress } = event.data;

    // Update lesson bar
    const bar = document.querySelector(`.lesson-progress-bar[data-lesson-id="${lessonId}"]`);
    if (bar) {
        const fill = bar.querySelector(".progress-fill");
        if (fill) fill.style.width = `${progress}%`;
    }

    // Force fresh server progress (also updates localStorage)
    fetchOverallProgress();
});

    // Initial apply (keep server value as priority)
    const saved = localStorage.getItem(`courseProgress_${courseId}`);
    const final = (serverProgress > 0) ? serverProgress : (saved ? parseInt(saved, 10) : 0);
    applyOverallProgress(final);
  });
  </script>

