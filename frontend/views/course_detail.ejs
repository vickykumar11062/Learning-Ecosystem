  <script>
    // Flash message functions
    let flashTimeout;
    
    function showFlash(message, type = 'info') {
      // Clear any existing timeout
      if (flashTimeout) {
        clearTimeout(flashTimeout);
        flashTimeout = null;
      }
      
      const container = document.getElementById('flash-container');
      const flashText = document.getElementById('flash-text');
      const flashMsg = document.getElementById('flash-message');
      
      // Set message and type
      flashText.textContent = message;
      
      // Update alert class based on type
      flashMsg.className = `alert alert-${type} alert-dismissible fade show`;
      
      // Show the container and message
      container.style.display = 'block';
      flashMsg.style.display = 'block';
      
      // Force reflow to enable animation
      void flashMsg.offsetWidth;
      
      // Add show class for animation
      flashMsg.classList.add('show');
      
      // Auto-hide after 5 seconds
      flashTimeout = setTimeout(hideFlash, 5000);
    }
    
    function hideFlash() {
      const container = document.getElementById('flash-container');
      const flashMsg = document.getElementById('flash-message');
      
      if (flashMsg && container) {
        // Start fade out animation
        flashMsg.classList.remove('show');
        
        // After animation completes, hide elements
        setTimeout(() => {
          flashMsg.style.display = 'none';
          container.style.display = 'none';
          flashMsg.className = 'alert alert-dismissible fade';
        }, 150); // Match this with CSS transition duration
      }
    }
    
 // ✅ Show flash messages from server if they exist
<% if (typeof error_msg !== 'undefined' && error_msg) { %>
