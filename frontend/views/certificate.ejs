<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      background: #f0f4f8;
      font-family: 'Poppins', sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      padding: 20px;
    }
    .certificate {
      background: #fff;
      border: 10px solid #6366f1;
      width: 100%;
      max-width: 900px;
      padding: 40px;
      text-align: center;
      box-shadow: 0 20px 50px rgba(0,0,0,0.2);
      border-radius: 20px;
      position: relative;
      margin: 20px 0;
    }
    .certificate h1 {
      color: #1e293b;
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    .certificate h2 {
      color: #6366f1;
      font-size: 1.8rem;
      margin: 1.5rem 0;
    }
    .certificate p {
      color: #475569;
      font-size: 1.1rem;
      margin: 10px 0;
    }
    .name {
      font-size: 2rem;
      font-weight: 700;
      color: #111827;
      margin: 1.5rem 0;
      border-bottom: 2px solid #6366f1;
      display: inline-block;
      padding: 0.5rem 2rem;
    }
    .bottom-section {
      margin-top: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
    }
    .sign {
      text-align: left;
      min-width: 200px;
    }
    .sign p {
      margin: 0.25rem 0;
    }
    .logo {
      position: absolute;
      top: 30px;
      right: 30px;
      width: 120px;
      max-width: 25%;
    }
    .download-btn {
      margin-top: 2rem;
      background: #6366f1;
      color: #fff;
      border: none;
      padding: 0.8rem 1.5rem;
      border-radius: 10px;
      cursor: pointer;
      font-size: 1rem;
      transition: background-color 0.3s;
    }
    .download-btn:hover {
      background: #4f46e5;
    }
    @media (max-width: 768px) {
      .certificate {
        padding: 30px 20px;
      }
      .certificate h1 {
        font-size: 2rem;
      }
      .certificate h2 {
        font-size: 1.5rem;
      }
      .name {
        font-size: 1.5rem;
      }
      .logo {
        width: 80px;
        top: 15px;
        right: 15px;
      }
    }
  </style>
</head>
<body class="">
  <div class="certificate" id="certificate">
    <img src="/images/logo.png" alt="Logo" class="logo">
    <h1>Certificate of Completion</h1>
    <p>This is to certify that</p>
    <div class="name"><%= studentName %></div>
    <p>has successfully completed the course</p>
    <h2>"<%= courseTitle %>"</h2>
    <p>on <%= issuedDate %></p>

    <div class="bottom-section">
      <div class="sign">
        <p>______________________</p>
        <p><strong><%= instructorName %></strong></p>
        <p>Instructor</p>
      </div>
      <div>
        <p><strong>Certificate ID:</strong> <%= certificateId %></p>
        <p><strong>Issued On:</strong> <%= issuedDate %></p>
      </div>
    </div>

    <% if (download) { %>
      <script>
        // Auto-download the PDF when the page loads (for server-side generation)
        window.onload = function() {
          // This will trigger the browser's download
          window.location.href = '/certificate/<%= certificateId %>/download';
        };
      </script>
      <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Generating PDF...</span>
        </div>
        <p class="mt-2">Preparing your download...</p>
      </div>
    <% } else { %>
      <a href="/certificate/<%= certificateId %>/download" class="download-btn">
        <i class="fas fa-download me-2"></i>Download Certificate
      </a>
    <% } %>
  </div>

  <!-- Server-side download handling -->
  <script>
    // Any additional client-side scripts can go here
  </script>
</body>
</html>
