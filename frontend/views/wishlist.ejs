<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist - EduLearn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('./partials/head') %>
</head>
<body class="">
    <%- include('./partials/navbar') %>
    
    <!-- Spacer for fixed navbar -->
    <div style="height: 30px;"></div>

    <!-- Flash Messages -->
    <div class="flash-messages" style="position: fixed; top: 80px; left: 50%; transform: translateX(-50%); z-index: 9999; width: auto; max-width: 500px; min-width: 300px; padding: 0 15px;">
        <% if (success_msg) { %>
            <% (Array.isArray(success_msg) ? success_msg : [success_msg]).forEach(function(msg) { %>
                <% if (msg && typeof msg === 'string' && msg.trim() !== '') { %>
                    <div class="alert alert-success alert-dismissible fade show mb-2" role="alert">
                        <%= msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
            <% }); %>
        <% } %>
        <% if (error_msg) { %>
            <% (Array.isArray(error_msg) ? error_msg : [error_msg]).forEach(function(msg) { %>
                <% if (msg && typeof msg === 'string' && msg.trim() !== '') { %>
                    <div class="alert alert-danger alert-dismissible fade show mb-2" role="alert">
                        <%= msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
            <% }); %>
        <% } %>
    </div>

    <main class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom">
          <div class="d-flex justify-content-between align-items-center">
            <h1 class="h4 mb-0">
              <i class="fas fa-heart text-danger me-2"></i>My Wishlist
            </h1>
            <span class="badge bg-primary">Coming Soon</span>
          </div>
        </div>
        
        <div class="card-body p-4">
          <div class="text-center py-5">
            <div class="mb-4">
              <i class="fas fa-heart text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
            </div>
            <h3 class="h5 mb-3">Your wishlist is empty</h3>
            <p class="text-muted mb-4">Save your favorite courses to your wishlist to access them later.</p>
            <a href="/courses" class="btn btn-primary">
              <i class="fas fa-book me-2"></i>Browse Courses
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

    </main>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
    <%- include('./partials/cookie-consent') %>
</body>
</html>
